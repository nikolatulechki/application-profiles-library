@prefix dash:  <http://datashapes.org/dash#> .
@prefix dcterms:    <http://purl.org/dc/terms/> .
@prefix dcat:    <http://www.w3.org/ns/dcat#> .

dl453:Ontology  rdf:type         owl:Ontology ;
        dcterms:conformsTo        "urn:iso:std:iec:61970-501:draft:ed-2" , "urn:iso:std:iec:61970-600-2:ed-1" , "urn:iso:std:iec:61970-301:ed-7:amd1" , "file://iec61970cim17v40_iec61968cim13v13a_iec62325cim03v17a.eap" ;
        dcterms:creator           "ENTSO-E CIM EG"@en ;
        dcterms:description       "The constraints for the DL profile from IEC 61970-453."@en ;
        dcterms:identifier        "0b4d0724-609c-412a-84c5-b3281732df22" ;
        dcterms:issued            "2021-10-19T12:09:21Z"^^xsd:dateTime ;
        dcterms:language          "en-GB" ;
        dcterms:modified          "2020-10-19"^^xsd:date ;
        dcterms:publisher         "ENTSO-E"@en ;
        dcterms:rights            "Copyright"@en ;
        dcterms:rightsHolder      "ENTSO-E"@en ;
        dcterms:title             "DL Constraints"@en ;
        owl:versionIRI        <http://iec.ch/TC57/ns/CIM/DiagramLayout-EU/constraints/IEC61970-453/3.0> ;
        owl:versionInfo       "3.0.0"@en ;
        dcat:landingPage      "https://www.entsoe.eu/digital/cim/cim-for-grid-models-exchange/" ;
        dcat:theme            "constraints"@en .

dl453:ValueConstraints453Group
        a           sh:PropertyGroup ;
        rdfs:label  "ValueConstraints" ;
        sh:order    0 .

dl453:DiagramStyle
        a               sh:NodeShape ;
        sh:property     dl453:DiagramStyle-allowedNameValues ;
        sh:targetClass  cim:DiagramStyle .
        
dl453:DiagramStyle-allowedNameValues
        a               sh:PropertyShape ;
        sh:in           ( "node-breaker" "bus-branch" "hybrid (node-breaker and bus-branch)" "geoschematic") ;
        sh:description  "The inherited IdentifiedObject.name shall have one of the following names: node-breaker, bus-branch, hybrid (node-breaker and bus-branch) or geoschematic." ;
        sh:group        dl453:ValueConstraints453Group ;
        sh:message      "Not allowed value." ;
        sh:name         "C:453:DL:DiagramStyle:name" ;
        sh:order        1 ;
        sh:path         cim:IdentifiedObject.name ;
        sh:severity     sh:Violation .         