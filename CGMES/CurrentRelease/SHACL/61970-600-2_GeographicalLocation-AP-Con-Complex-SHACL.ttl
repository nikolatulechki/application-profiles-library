gl600:Ontology  rdf:type         owl:Ontology ;
        dcterms:conformsTo        "urn:iso:std:iec:61970-501:draft:ed-2" , "urn:iso:std:iec:61970-600-2:ed-1" , "urn:iso:std:iec:61970-301:ed-7:amd1" , "file://iec61970cim17v40_iec61968cim13v13a_iec62325cim03v17a.eap" ;
        dcterms:creator           "ENTSO-E CIM EG"@en ;
        dcterms:description       "The constraints for GL profile from IEC 61970-600-2."@en ;
        dcterms:identifier        "bc549178-1772-4690-b0d1-c8451c225863" ;
        dcterms:issued            "2021-10-19T12:09:21Z"^^xsd:dateTime ;
        dcterms:language          "en-GB" ;
        dcterms:modified          "2020-10-19"^^xsd:date ;
        dcterms:publisher         "ENTSO-E"@en ;
        dcterms:rights            "Copyright"@en ;
        dcterms:rightsHolder      "ENTSO-E"@en ;
        dcterms:title             "GL Constraints"@en ;
        owl:versionIRI        <http://iec.ch/TC57/ns/CIM/GeographicalLocation-EU/constraints/IEC61970-600-2/3.0> ;
        owl:versionInfo       "3.0.0"@en ;
        dcat:landingPage      "https://www.entsoe.eu/digital/cim/cim-for-grid-models-exchange/" ;
        dcat:theme            "constraints"@en .

gl600:GL600Part2Group
        a           sh:PropertyGroup ;
        rdfs:label  "GL600Part2" ;
        sh:order    0 .

#gl600:Location
#        a               sh:NodeShape ;
#        sh:property     gl600:Location-position ;
#        sh:targetClass  cim:Location .


gl600:Location-position
        #a               sh:PropertyShape ;
        a               sh:NodeShape ;
        sh:description  "IEC 61968-13 allows both PositionPoint and mainAddress to be exchanged. CGMES requires that PositionPoint is exchanged and mainAddress is not exchanged." ;
        sh:name         "C:600:GL:NA:position" ;
        sh:message "Either Location.mainAddress is provided or the Location is not referenced by a PositionPoint." ;
        sh:order        0 ;
        sh:and (
                [sh:path  cim:Location.mainAddress ;
                 sh:maxCount  0;
                ]
                [sh:path         [sh:inversePath  cim:PositionPoint.Location] ; ;
                 sh:minCount  1;
                ]
        );
        sh:group        gl600:GL600Part2Group ;
        sh:severity     sh:Violation ;
        sh:targetClass  cim:Location .
        
    