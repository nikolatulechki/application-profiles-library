        sh:group        ido:CardinalityIO;
        sh:maxCount     1;
        sh:message      "Missing required property (attribute).";
        sh:minCount     1;
        sh:name         "IdentifiedObject.mRID-cardinality";
        sh:order        0.1;
        sh:path         cim:IdentifiedObject.mRID;
        sh:severity     sh:Violation .

er:ACPointOfCommonCoupling.ConnectivityNode-valueType
        rdf:type        sh:PropertyShape;
        sh:class        cim:ConnectivityNode;
        sh:description  "This constraint validates the value of the association at the used direction.";
        sh:group        er:AssociationsGroup;
        sh:message      "One of the following does not conform: 1) The value shall be IRI; 2) The value shall be an instance of the class: cim18:ConnectivityNode";
        sh:name         "ACPointOfCommonCoupling.ConnectivityNode-valueType";
        sh:nodeKind     sh:IRI;
        sh:order        1;
        sh:path         nc:ACPointOfCommonCoupling.ConnectivityNode;
        sh:severity     sh:Violation .

er:ACPointOfCommonCoupling.ConnectivityNode-cardinality
        rdf:type        sh:PropertyShape;
        sh:description  "This constraint validates the cardinality of the association at the used direction.";
        sh:group        er:CardinalityGroup;
        sh:maxCount     1;
        sh:message      "Association with cardinality violation at the used direction.";
        sh:minCount     1;
        sh:name         "ACPointOfCommonCoupling.ConnectivityNode-cardinality";
        sh:order        2;
        sh:path         nc:ACPointOfCommonCoupling.ConnectivityNode;
        sh:severity     sh:Violation .

er:ACPointOfCommonCoupling.DCConverterUnit-cardinality
        rdf:type        sh:PropertyShape;
        sh:description  "This constraint validates the cardinality of the association at the inverse direction.";
        sh:group        er:CardinalityGroup;
        sh:maxCount     1;
        sh:message      "Cardinality violation. Upper bound shall be 1";
        sh:name         "ACPointOfCommonCoupling.DCConverterUnit-cardinality";
        sh:order        1;
        sh:path         [ sh:inversePath  nc:DCConverterUnit.ACPointOfCommonCoupling ];
        sh:severity     sh:Violation .

er:ACPointOfCommonCoupling.DCConverterUnit-propertyInverse
        rdf:type        sh:PropertyShape;
        sh:description  "Inverse associations shall not be instantiated.";
        sh:group        er:InverseAssociationsGroup;
        sh:maxCount     0;
        sh:message      "Inverse association is present.";
        sh:name         "InverseAssociationPresent";
        sh:order        1;
        sh:path         nc:ACPointOfCommonCoupling.DCConverterUnit;
        sh:severity     sh:Violation .

er:ACPointOfCommonCoupling.DCConverterUnit-inverseNodePresent
        rdf:type             sh:NodeShape;
        sh:property          er:ACPointOfCommonCoupling.DCConverterUnit-propertyInverse;
        sh:targetSubjectsOf  nc:ACPointOfCommonCoupling.DCConverterUnit .

er:ACPointOfCommonCoupling-AllowedProperties
        rdf:type              sh:NodeShape;
        sh:closed             true;
        sh:description        "Checks if the dataset contains properties which are not defined in the profile to which this dataset conforms to.";
        sh:group              er:ProfilePropertiesGroup;
        sh:ignoredProperties  ( rdf:type );
        sh:message            "This property is not part of the profile to which this dataset conforms to.";
        sh:name               "PropertyNotInProfile";
        sh:order              1;
        sh:property           [ sh:path  cim:IdentifiedObject.name ];
        sh:property           [ sh:path  cim:IdentifiedObject.description ];
        sh:property           [ sh:path  <https://cim.ucaiug.io/ns/eu#IdentifiedObject.energyIdentCodeEic> ];
        sh:property           [ sh:path  cim:IdentifiedObject.mRID ];
        sh:property           [ sh:path  nc:ACPointOfCommonCoupling.ConnectivityNode ];
        sh:severity           sh:Info;
        sh:targetClass        nc:ACPointOfCommonCoupling .

er:ACPointOfCommonCoupling
        rdf:type        sh:NodeShape;
        sh:property     ido:IdentifiedObject.name-datatype , ido:IdentifiedObject.name-cardinality , ido:IdentifiedObject.description-datatype , ido:IdentifiedObject.description-cardinality , ido:IdentifiedObject.energyIdentCodeEic-datatype , ido:IdentifiedObject.energyIdentCodeEic-cardinality , ido:IdentifiedObject.mRID-datatype , ido:IdentifiedObject.mRID-cardinality , er:ACPointOfCommonCoupling.ConnectivityNode-valueType , er:ACPointOfCommonCoupling.ConnectivityNode-cardinality , er:ACPointOfCommonCoupling.DCConverterUnit-cardinality;
        sh:targetClass  nc:ACPointOfCommonCoupling .

cc:     rdf:type     owl:Ontology;
        owl:imports  sh:;
        sh:declare   [ rdf:type      sh:PrefixDeclaration;
                       sh:namespace  "http://www.w3.org/1999/02/22-rdf-syntax-ns#";
                       sh:prefix     "rdf"
                     ] .

cc:ClassCount-propertySparql
        rdf:type     sh:SPARQLConstraint;
        sh:message   "The class {?class} appears {?value} times in the data graph.";
        sh:prefixes  cc:;
        sh:select    """ 
            SELECT $this ?class (COUNT(?instance) AS ?value)
            WHERE {
                    ?instance rdf:type ?class .
                   }
            GROUP BY $this ?class
             """ .

cc:ClassCount-property
        rdf:type        sh:PropertyShape;
        sh:description  "Counts instance of classes present in the data graph.";
        sh:group        cc:ClassesCountGroup;
        sh:name         "ClassCount";
        sh:order        1;
        sh:path         rdf:type;
        sh:severity     sh:Info;
        sh:sparql       cc:ClassCount-propertySparql .

cc:ClassCount-node  rdf:type  sh:NodeShape;
        sh:property    cc:ClassCount-property;
        sh:targetClass  md:FullModel , dcat:Dataset .

cc:ClassesCountGroup  rdf:type  sh:PropertyGroup;
        rdfs:label  "ClassesCount";
        sh:order    1 .

