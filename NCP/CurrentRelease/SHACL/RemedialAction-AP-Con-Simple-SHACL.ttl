ra:PinTerminal.Terminal-valueType
        rdf:type        sh:PropertyShape;
        sh:class        cim:Terminal;
        sh:description  "This constraint validates the value of the association at the used direction.";
        sh:group        ra:AssociationsGroup;
        sh:message      "One of the following does not conform: 1) The value shall be IRI; 2) The value shall be an instance of the class: cim18:Terminal";
        sh:name         "PinTerminal.Terminal-valueType";
        sh:nodeKind     sh:IRI;
        sh:order        104;
        sh:path         nc:PinTerminal.Terminal;
        sh:severity     sh:Violation .

ra:PinTerminal.Terminal-cardinality
        rdf:type        sh:PropertyShape;
        sh:description  "This constraint validates the cardinality of the association at the used direction.";
        sh:group        ra:CardinalityGroup;
        sh:maxCount     1;
        sh:message      "Association with cardinality violation at the used direction.";
        sh:minCount     1;
        sh:name         "PinTerminal.Terminal-cardinality";
        sh:order        484;
        sh:path         nc:PinTerminal.Terminal;
        sh:severity     sh:Violation .

