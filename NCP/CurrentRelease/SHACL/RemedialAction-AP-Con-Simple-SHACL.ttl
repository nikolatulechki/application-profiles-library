        sh:ignoredProperties  ( rdf:type );
        sh:message            "This property is not part of the profile to which this dataset conforms to.";
        sh:name               "PropertyNotInProfile";
        sh:order              1;
        sh:property           [ sh:path  nc:PinGate.GateOutput ];
        sh:property           [ sh:path  nc:GateInputPin.isValuePreFault ];
        sh:property           [ sh:path  nc:GateInputPin.negate ];
        sh:property           [ sh:path  nc:GateInputPin.thresholdPercentage ];
        sh:property           [ sh:path  nc:GateInputPin.duration ];
        sh:property           [ sh:path  nc:GateInputPin.thresholdValue ];
        sh:property           [ sh:path  nc:GateInputPin.Gate ];
        sh:property           [ sh:path  nc:GateInputPin.logicKind ];
        sh:property           [ sh:path  nc:GateInputPin.absoluteValue ];
        sh:property           [ sh:path  cim:IdentifiedObject.mRID ];
        sh:property           [ sh:path  cim:IdentifiedObject.description ];
        sh:property           [ sh:path  cim:IdentifiedObject.name ];
        sh:severity           sh:Info;
        sh:targetClass        nc:PinGate .

ra:PinGate  rdf:type    sh:NodeShape;
        sh:property     ido:IdentifiedObject.name-datatype , ido:IdentifiedObject.name-cardinality , ido:IdentifiedObject.description-datatype , ido:IdentifiedObject.description-cardinality , ido:IdentifiedObject.mRID-datatype , ido:IdentifiedObject.mRID-cardinality , ra:GateInputPin.absoluteValue-datatype , ra:GateInputPin.absoluteValue-cardinality , ra:GateInputPin.logicKind-datatype , ra:GateInputPin.logicKind-cardinality , ra:PinGate.GateOutput-cardinality , ra:PinGate.GateOutput-valueType , ra:GateInputPin.isValuePreFault-cardinality , ra:GateInputPin.isValuePreFault-datatype , ra:GateInputPin.negate-cardinality , ra:GateInputPin.negate-datatype , ra:GateInputPin.thresholdPercentage-cardinality , ra:GateInputPin.thresholdPercentage-datatype , ra:GateInputPin.duration-cardinality , ra:GateInputPin.duration-datatype , ra:GateInputPin.thresholdValue-cardinality , ra:GateInputPin.thresholdValue-datatype , ra:GateInputPin.Gate-cardinality , ra:GateInputPin.Gate-valueType;
        sh:targetClass  nc:PinGate .

cc:     rdf:type     owl:Ontology;
        owl:imports  sh:;
        sh:declare   [ rdf:type      sh:PrefixDeclaration;
                       sh:namespace  "http://www.w3.org/1999/02/22-rdf-syntax-ns#";
                       sh:prefix     "rdf"
                     ] .

cc:ClassCount-propertySparql
        rdf:type     sh:SPARQLConstraint;
        sh:message   "The class {?class} appears {?value} times in the data graph.";
        sh:prefixes  cc:;
        sh:select    """ 
            SELECT $this ?class (COUNT(?instance) AS ?value)
            WHERE {
                    ?instance rdf:type ?class .
                   }
            GROUP BY $this ?class
             """ .

cc:ClassCount-property
        rdf:type        sh:PropertyShape;
        sh:description  "Counts instance of classes present in the data graph.";
        sh:group        cc:ClassesCountGroup;
        sh:name         "ClassCount";
        sh:order        1;
        sh:path         rdf:type;
        sh:severity     sh:Info;
        sh:sparql       cc:ClassCount-propertySparql .

cc:ClassCount-node  rdf:type  sh:NodeShape;
        sh:property    cc:ClassCount-property;
        sh:targetClass  dcat:Dataset .

cc:ClassesCountGroup  rdf:type  sh:PropertyGroup;
        rdfs:label  "ClassesCount";
        sh:order    1 .

ra:AllowedClasses-property
        rdf:type        sh:PropertyShape;
        sh:description  "Checks if the dataset contains classes which are not defined in the profile to which this dataset conforms to.";
        sh:group        ra:ProfileClassesGroup;
        sh:in           ( nc:PinGate nc:MeasurementCalculatorInput nc:ContingencyWithRemedialAction nc:PowerShiftKeyStrategy nc:IntertemporalPropertyRange nc:LoadAction nc:PinPowerTransferCorridor nc:PinMeasurement nc:PinDCTerminal nc:PinEquipmentTripping nc:PinOperationalLimit nc:PinContingency nc:PinEquipment nc:PinTerminal nc:StaticVarCompensatorAction nc:RemedialActionDependency nc:RemedialActionScheme nc:RedispatchRemedialAction nc:CountertradeRemedialAction nc:GridStateAlterationRemedialAction nc:SchemeRemedialAction nc:AvailabilityRemedialAction nc:ExternalNetworkInjectionAction cim:Substation nc:SecondarySubstation nc:TopologyAction nc:EquipmentControllerAction nc:InServiceAction nc:StaticPropertyRange nc:ACDCConverterAction nc:BatteryUnitAction nc:ControlFunctionBlockAction nc:PowerElectronicsConnectionAction nc:ShuntCompensatorModification nc:RotatingMachineAction nc:EquivalentInjectionAction nc:EnergySourceModification nc:BiddingZoneAction nc:TapPositionAction nc:RegulatingControlAction nc:StageTrigger nc:GridStateAlterationCollection nc:PTCActivePowerSupport nc:RemedialActionGroup nc:Gate nc:MeasurementCalculator nc:TriggerCondition nc:Stage md:FullModel dm:DifferenceModel dcat:Dataset );
        sh:message      "This class is not part of the profile to which this dataset conforms to.";
        sh:name         "ClassNotInProfile";
        sh:order        1;
        sh:path         rdf:type;
        sh:severity     sh:Info .

ra:AllowedClasses-node
        rdf:type             sh:NodeShape;
        sh:property          ra:AllowedClasses-property;
        sh:targetSubjectsOf  rdf:type .

ra:ProfilePropertiesGroup
        rdf:type    sh:PropertyGroup;
        rdfs:label  "ProfileProperties";
        sh:order    1 .

ra:AssociationsGroup  rdf:type  sh:PropertyGroup;
        rdfs:label  "Associations";
        sh:order    2 .

ido:DatatypesGroupIO  rdf:type  sh:PropertyGroup;
        rdfs:label  "DatatypesIO";
        sh:order    1 .

ra:ProfileClassesGroup
        rdf:type    sh:PropertyGroup;
        rdfs:label  "ProfileClasses";
        sh:order    1 .

ra:InverseAssociationsGroup
        rdf:type    sh:PropertyGroup;
        rdfs:label  "InverseAssociations";
        sh:order    1 .

ra:DatatypesGroup  rdf:type  sh:PropertyGroup;
        rdfs:label  "Datatypes";
        sh:order    1 .

ido:CardinalityGroup  rdf:type  sh:PropertyGroup;
        rdfs:label  "CardinalityIO";
        sh:order    0 .

ra:CardinalityGroup  rdf:type  sh:PropertyGroup;
        rdfs:label  "Cardinality";
        sh:order    0 .
