ae:AssessedElementWithRemedialAction.RemedialAction-valueType
        rdf:type        sh:PropertyShape;
        sh:description  "This constraint validates the value of the association at the used direction.";
        sh:group        ae:AssociationsGroup;
        sh:in           ( nc:RedispatchRemedialAction nc:CountertradeRemedialAction nc:AvailabilityRemedialAction nc:SchemeRemedialAction nc:GridStateAlterationRemedialAction );
