ae:AssessedElementWithContingency.combinationConstraintKind-cardinality
        rdf:type        sh:PropertyShape;
        sh:description  "This constraint validates the cardinality of the property (attribute).";
        sh:group        ae:CardinalityGroup;
        sh:maxCount     1;
        sh:message      "Missing required property (attribute).";
        sh:minCount     1;
        sh:name         "AssessedElementWithContingency.combinationConstraintKind-cardinality";
        sh:order        3;
        sh:path         nc:AssessedElementWithContingency.combinationConstraintKind;
        sh:severity     sh:Violation .

ae:AssessedElementWithContingency.normalEnabled-datatype
        rdf:type        sh:PropertyShape;
        sh:datatype     xsd:boolean;
        sh:description  "This constraint validates the datatype of the property (attribute).";
        sh:group        ae:DatatypesGroup;
        sh:message      "The datatype is not literal or it violates the xsd datatype.";
        sh:name         "AssessedElementWithContingency.normalEnabled-datatype";
        sh:nodeKind     sh:Literal;
        sh:order        -1;
        sh:path         nc:AssessedElementWithContingency.normalEnabled;
        sh:severity     sh:Violation .

ae:AssessedElementWithContingency.normalEnabled-cardinality
        rdf:type        sh:PropertyShape;
        sh:description  "This constraint validates the cardinality of the property (attribute).";
        sh:group        ae:CardinalityGroup;
        sh:maxCount     1;
        sh:message      "Cardinality violation. Upper bound shall be 1";
        sh:name         "AssessedElementWithContingency.normalEnabled-cardinality";
        sh:order        2;
        sh:path         nc:AssessedElementWithContingency.normalEnabled;
        sh:severity     sh:Violation .

ae:AssessedElementWithContingency.Contingency-valueType
        rdf:type        sh:PropertyShape;
        sh:description  "This constraint validates the value of the association at the used direction.";
        sh:group        ae:AssociationsGroup;
        sh:in           ( nc:OutOfRangeContingency nc:ExceptionalContingency nc:OrdinaryContingency );
        sh:message      "One of the following occurs: 1) The value is not IRI; 2) The value is not the right class.";
        sh:name         "AssessedElementWithContingency.Contingency-valueType";
        sh:nodeKind     sh:IRI;
        sh:order        1;
        sh:path         ( nc:AssessedElementWithContingency.Contingency rdf:type );
        sh:severity     sh:Violation .

ae:AssessedElementWithContingency.Contingency-valueTypeNodeShape
        rdf:type        sh:NodeShape;
        sh:property     ae:AssessedElementWithContingency.Contingency-valueType;
        sh:targetClass  nc:AssessedElementWithContingency .

ae:AssessedElementWithContingency.Contingency-cardinality
        rdf:type        sh:PropertyShape;
        sh:description  "This constraint validates the cardinality of the association at the used direction.";
        sh:group        ae:CardinalityGroup;
        sh:maxCount     1;
        sh:message      "Association with cardinality violation at the used direction.";
        sh:minCount     1;
        sh:name         "AssessedElementWithContingency.Contingency-cardinality";
        sh:order        1;
        sh:path         nc:AssessedElementWithContingency.Contingency;
        sh:severity     sh:Violation .

ae:AssessedElementWithContingency-AllowedProperties
        rdf:type              sh:NodeShape;
        sh:closed             true;
        sh:description        "Checks if the dataset contains properties which are not defined in the profile to which this dataset conforms to.";
        sh:group              ae:ProfilePropertiesGroup;
        sh:ignoredProperties  ( rdf:type );
        sh:message            "This property is not part of the profile to which this dataset conforms to.";
        sh:name               "PropertyNotInProfile";
        sh:order              1;
        sh:property           [ sh:path  nc:AssessedElementWithContingency.AssessedElement ];
        sh:property           [ sh:path  nc:AssessedElementWithContingency.mRID ];
        sh:property           [ sh:path  nc:AssessedElementWithContingency.combinationConstraintKind ];
        sh:property           [ sh:path  nc:AssessedElementWithContingency.normalEnabled ];
        sh:property           [ sh:path  nc:AssessedElementWithContingency.Contingency ];
        sh:severity           sh:Info;
        sh:targetClass        nc:AssessedElementWithContingency .

ae:AssessedElementWithContingency
        rdf:type        sh:NodeShape;
        sh:property     ae:AssessedElementWithContingency.AssessedElement-valueType , ae:AssessedElementWithContingency.AssessedElement-cardinality , ae:AssessedElementWithContingency.mRID-datatype , ae:AssessedElementWithContingency.mRID-cardinality , ae:AssessedElementWithContingency.combinationConstraintKind-datatype , ae:AssessedElementWithContingency.combinationConstraintKind-cardinality , ae:AssessedElementWithContingency.normalEnabled-datatype , ae:AssessedElementWithContingency.normalEnabled-cardinality , ae:AssessedElementWithContingency.Contingency-cardinality;
        sh:targetClass  nc:AssessedElementWithContingency .

cc:     rdf:type     owl:Ontology;
        owl:imports  sh:;
        sh:declare   [ rdf:type      sh:PrefixDeclaration;
                       sh:namespace  "http://www.w3.org/1999/02/22-rdf-syntax-ns#";
                       sh:prefix     "rdf"
                     ] .

cc:ClassCount-propertySparql
        rdf:type     sh:SPARQLConstraint;
        sh:message   "The class {?class} appears {?value} times in the data graph.";
        sh:prefixes  cc:;
        sh:select    """ 
            SELECT $this ?class (COUNT(?instance) AS ?value)
            WHERE {
                    ?instance rdf:type ?class .
                   }
            GROUP BY $this ?class
             """ .

cc:ClassCount-property
        rdf:type        sh:PropertyShape;
        sh:description  "Counts instance of classes present in the data graph.";
        sh:group        cc:ClassesCountGroup;
        sh:name         "ClassCount";
        sh:order        1;
        sh:path         rdf:type;
        sh:severity     sh:Info;
        sh:sparql       cc:ClassCount-propertySparql .

cc:ClassCount-node  rdf:type  sh:NodeShape;
        sh:property    cc:ClassCount-property;
        sh:targetClass  dcat:Dataset, md:FullModel .

cc:ClassesCountGroup  rdf:type  sh:PropertyGroup;
        rdfs:label  "ClassesCount";
        sh:order    1 .

ae:AllowedClasses-property
        rdf:type        sh:PropertyShape;
        sh:description  "Checks if the dataset contains classes which are not defined in the profile to which this dataset conforms to.";
        sh:group        ae:ProfileClassesGroup;
        sh:in           ( nc:AssessedElementWithContingency nc:AssessedElement nc:AssessedElementWithRemedialAction md:FullModel dm:DifferenceModel dcat:Dataset );
        sh:message      "This class is not part of the profile to which this dataset conforms to.";
        sh:name         "ClassNotInProfile";
        sh:order        1;
        sh:path         rdf:type;
        sh:severity     sh:Info .

ae:AllowedClasses-node
        rdf:type             sh:NodeShape;
        sh:property          ae:AllowedClasses-property;
        sh:targetSubjectsOf  rdf:type .

ae:ProfilePropertiesGroup
        rdf:type    sh:PropertyGroup;
        rdfs:label  "ProfileProperties";
        sh:order    1 .

ae:AssociationsGroup  rdf:type  sh:PropertyGroup;
        rdfs:label  "Associations";
        sh:order    2 .

ido:DatatypesGroupIO  rdf:type  sh:PropertyGroup;
        rdfs:label  "DatatypesIO";
        sh:order    1 .

ae:ProfileClassesGroup
        rdf:type    sh:PropertyGroup;
        rdfs:label  "ProfileClasses";
        sh:order    1 .

ae:InverseAssociationsGroup
        rdf:type    sh:PropertyGroup;
        rdfs:label  "InverseAssociations";
        sh:order    1 .

ae:DatatypesGroup  rdf:type  sh:PropertyGroup;
        rdfs:label  "Datatypes";
        sh:order    1 .

ido:CardinalityGroup  rdf:type  sh:PropertyGroup;
        rdfs:label  "CardinalityIO";
        sh:order    0 .

ae:CardinalityGroup  rdf:type  sh:PropertyGroup;
        rdfs:label  "Cardinality";
        sh:order    0 .
