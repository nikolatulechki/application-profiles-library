        sh:severity     sh:Violation .

ae:AssessedElementWithRemedialAction-AllowedProperties
        rdf:type              sh:NodeShape;
        sh:closed             true;
        sh:description        "Checks if the dataset contains properties which are not defined in the profile to which this dataset conforms to.";
        sh:group              ae:ProfilePropertiesGroup;
        sh:ignoredProperties  ( rdf:type );
        sh:message            "This property is not part of the profile to which this dataset conforms to.";
        sh:name               "PropertyNotInProfile";
        sh:order              3;
        sh:property           [ sh:path  nc:AssessedElementWithRemedialAction.AssessedElement ];
        sh:property           [ sh:path  nc:AssessedElementWithRemedialAction.mRID ];
        sh:property           [ sh:path  nc:AssessedElementWithRemedialAction.combinationConstraintKind ];
        sh:property           [ sh:path  nc:AssessedElementWithRemedialAction.normalEnabled ];
        sh:property           [ sh:path  nc:AssessedElementWithRemedialAction.RemedialAction ];
        sh:severity           sh:Info;
        sh:targetClass        nc:AssessedElementWithRemedialAction .

ae:AssessedElementWithRemedialAction
        rdf:type        sh:NodeShape;
        sh:property     ae:AssessedElementWithRemedialAction.AssessedElement-valueType , ae:AssessedElementWithRemedialAction.AssessedElement-cardinality , ae:AssessedElementWithRemedialAction.mRID-datatype , ae:AssessedElementWithRemedialAction.mRID-cardinality , ae:AssessedElementWithRemedialAction.combinationConstraintKind-datatype , ae:AssessedElementWithRemedialAction.combinationConstraintKind-cardinality , ae:AssessedElementWithRemedialAction.normalEnabled-datatype , ae:AssessedElementWithRemedialAction.normalEnabled-cardinality , ae:AssessedElementWithRemedialAction.RemedialAction-cardinality;
        sh:targetClass  nc:AssessedElementWithRemedialAction .

