as:AvailabilityRemedialActionScheme.RemedialActionScheme-valueType
        rdf:type        sh:PropertyShape;
        sh:class        nc:RemedialActionScheme;
        sh:description  "This constraint validates the value of the association at the used direction.";
        sh:group        as:AssociationsGroup;
        sh:message      "One of the following does not conform: 1) The value shall be IRI; 2) The value shall be an instance of the class: nc:RemedialActionScheme";
        sh:name         "AvailabilityRemedialActionScheme.RemedialActionScheme-valueType";
        sh:nodeKind     sh:IRI;
        sh:order        21;
        sh:path         nc:AvailabilityRemedialActionScheme.RemedialActionScheme;
        sh:severity     sh:Violation .

as:AvailabilityRemedialActionScheme.RemedialActionScheme-cardinality
        rdf:type        sh:PropertyShape;
        sh:description  "This constraint validates the cardinality of the association at the used direction.";
        sh:group        as:CardinalityGroup;
        sh:maxCount     1;
        sh:message      "Association with cardinality violation at the used direction.";
        sh:minCount     1;
        sh:name         "AvailabilityRemedialActionScheme.RemedialActionScheme-cardinality";
        sh:order        64;
        sh:path         nc:AvailabilityRemedialActionScheme.RemedialActionScheme;
        sh:severity     sh:Violation .

