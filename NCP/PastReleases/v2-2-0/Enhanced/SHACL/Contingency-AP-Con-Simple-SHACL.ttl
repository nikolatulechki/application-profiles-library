co:Ontology  rdf:type     owl:Ontology;
        dcterms:conformsTo    "file://CGMES-30v25_501-20v01.eap" , "file://iec61970cim17v40_iec61968cim13v13a_iec62325cim03v17a.eap" , "urn:iso:std:iec:61970-600-2:ed-1" , "urn:iso:std:iec:61970-401:draft:ed-1" , "urn:iso:std:iec:61970-501:draft:ed-2" , "urn:iso:std:iec:61970-301:ed-7:amd1";
        dcterms:description   "Describing constraints extracted from RDFS.";
        dcterms:identifier    "urn:uuida12ebb1c-6046-470a-99b3-431dc47bc748";
        dcterms:issued        "2025-10-04T06:58:45.129835100"^^xsd:dateTime;
        dcterms:language      "en-GB";
        dcterms:license       "https://www.apache.org/licenses/LICENSE-2.0"@en;
        dcterms:modified      "2023-04-20"^^xsd:date;
        dcterms:publisher     "ENTSO-E"@en;
        dcterms:rightsHolder  "ENTSO-E"@en;
        dcterms:title         "Contingency Vocabulary"@en;
        owl:versionIRI    <Constraints/2.2>;
        owl:versionInfo   "2.2.0"@en;
        dcat:keyword      "CO";
        dcat:theme        "constraint"@en .

co:OutOfRangeContingency-AllowedProperties
        rdf:type              sh:NodeShape;
        sh:closed             true;
        sh:description        "Checks if the dataset contains properties which are not defined in the profile to which this dataset conforms to.";
        sh:group              co:ProfilePropertiesGroup;
        sh:ignoredProperties  ( rdf:type );
        sh:message            "This property is not part of the profile to which this dataset conforms to.";
        sh:name               "PropertyNotInProfile";
        sh:order              4;
        sh:property           [ sh:path  nc:Contingency.normalMustStudy ];
        sh:property           [ sh:path  nc:Contingency.EquipmentOperator ];
        sh:property           [ sh:path  nc:Contingency.normalProbability ];
        sh:property           [ sh:path  cim:Contingency.SimulationEvents ];
        sh:property           [ sh:path  cim:IdentifiedObject.name ];
        sh:property           [ sh:path  cim:IdentifiedObject.mRID ];
        sh:property           [ sh:path  cim:IdentifiedObject.description ];
        sh:severity           sh:Info;
        sh:targetClass        nc:OutOfRangeContingency .

co:OutOfRangeContingency
        rdf:type        sh:NodeShape;
        sh:property     ido:IdentifiedObject.description-datatype , ido:IdentifiedObject.description-cardinality , ido:IdentifiedObject.mRID-datatype , ido:IdentifiedObject.mRID-cardinality , ido:IdentifiedObject.name-datatype , ido:IdentifiedObject.name-cardinality , co:Contingency.SimulationEvents-valueType , co:Contingency.SimulationEvents-cardinality , co:Contingency.normalProbability-datatype , co:Contingency.normalProbability-cardinality , co:Contingency.EquipmentOperator-cardinality , co:Contingency.normalMustStudy-datatype , co:Contingency.normalMustStudy-cardinality;
        sh:targetClass  nc:OutOfRangeContingency .

co:ExceptionalContingency.kind-datatype
        rdf:type        sh:PropertyShape;
        sh:description  "This constraint validates the datatype of the property (attribute).";
        sh:group        co:DatatypesGroup;
        sh:in           ( nc:ContingencyConditionKind.geographicalLocation nc:ContingencyConditionKind.environmental nc:ContingencyConditionKind.design nc:ContingencyConditionKind.malfunction nc:ContingencyConditionKind.operational );
        sh:message      "The datatype is not IRI (Internationalized Resource Identifier) or it is enumerated value not part of the profile.";
        sh:name         "ExceptionalContingency.kind-datatype";
        sh:nodeKind     sh:IRI;
        sh:order        8;
        sh:path         nc:ExceptionalContingency.kind;
        sh:severity     sh:Violation .

co:ExceptionalContingency.kind-cardinality
        rdf:type        sh:PropertyShape;
        sh:description  "This constraint validates the cardinality of the property (attribute).";
        sh:group        co:CardinalityGroup;
        sh:maxCount     1;
        sh:message      "Missing required property (attribute).";
        sh:minCount     1;
        sh:name         "ExceptionalContingency.kind-cardinality";
        sh:order        15;
        sh:path         nc:ExceptionalContingency.kind;
        sh:severity     sh:Violation .

co:ExceptionalContingency-AllowedProperties
        rdf:type              sh:NodeShape;
        sh:closed             true;
        sh:description        "Checks if the dataset contains properties which are not defined in the profile to which this dataset conforms to.";
        sh:group              co:ProfilePropertiesGroup;
        sh:ignoredProperties  ( rdf:type );
        sh:message            "This property is not part of the profile to which this dataset conforms to.";
        sh:name               "PropertyNotInProfile";
        sh:order              3;
        sh:property           [ sh:path  nc:ExceptionalContingency.kind ];
        sh:property           [ sh:path  nc:Contingency.normalMustStudy ];
        sh:property           [ sh:path  nc:Contingency.EquipmentOperator ];
        sh:property           [ sh:path  nc:Contingency.normalProbability ];
        sh:property           [ sh:path  cim:Contingency.SimulationEvents ];
        sh:property           [ sh:path  cim:IdentifiedObject.name ];
        sh:property           [ sh:path  cim:IdentifiedObject.mRID ];
        sh:property           [ sh:path  cim:IdentifiedObject.description ];
        sh:severity           sh:Info;
        sh:targetClass        nc:ExceptionalContingency .

co:ExceptionalContingency
        rdf:type        sh:NodeShape;
        sh:property     ido:IdentifiedObject.description-datatype , co:ExceptionalContingency.kind-cardinality , co:ExceptionalContingency.kind-datatype , co:Contingency.normalMustStudy-cardinality , co:Contingency.normalMustStudy-datatype , co:Contingency.EquipmentOperator-cardinality , co:Contingency.normalProbability-cardinality , co:Contingency.normalProbability-datatype , co:Contingency.SimulationEvents-cardinality , co:Contingency.SimulationEvents-valueType , ido:IdentifiedObject.name-cardinality , ido:IdentifiedObject.name-datatype , ido:IdentifiedObject.mRID-cardinality , ido:IdentifiedObject.mRID-datatype , ido:IdentifiedObject.description-cardinality;
        sh:targetClass  nc:ExceptionalContingency .

co:ContingencyElement.Contingency-valueType
        rdf:type        sh:PropertyShape;
        sh:description  "This constraint validates the value of the association at the used direction.";
        sh:group        co:AssociationsGroup;
        sh:in           ( nc:OutOfRangeContingency nc:OrdinaryContingency nc:ExceptionalContingency );
        sh:message      "One of the following occurs: 1) The value is not IRI; 2) The value is not the right class.";
        sh:name         "ContingencyElement.Contingency-valueType";
        sh:nodeKind     sh:IRI;
        sh:order        4;
        sh:path         ( cim:ContingencyElement.Contingency rdf:type );
        sh:severity     sh:Violation .

co:ContingencyElement.Contingency-valueTypeNodeShape
        rdf:type        sh:NodeShape;
        sh:property     co:ContingencyElement.Contingency-valueType;
        sh:targetClass  cim:ContingencyEquipment .

co:ContingencyElement.Contingency-cardinality
        rdf:type        sh:PropertyShape;
        sh:description  "This constraint validates the cardinality of the association at the used direction.";
        sh:group        co:CardinalityGroup;
        sh:maxCount     1;
        sh:message      "Association with cardinality violation at the used direction.";
        sh:minCount     1;
        sh:name         "ContingencyElement.Contingency-cardinality";
        sh:order        11;
        sh:path         cim:ContingencyElement.Contingency;
        sh:severity     sh:Violation .

co:ContingencyEquipment.contingentStatus-datatype
        rdf:type        sh:PropertyShape;
        sh:description  "This constraint validates the datatype of the property (attribute).";
