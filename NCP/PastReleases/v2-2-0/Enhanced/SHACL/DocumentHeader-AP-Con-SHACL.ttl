dh:Ontology  rdf:type     owl:Ontology;
        dcterms:conformsTo    "urn:iso:std:iec:61970-501:draft:ed-2" , "urn:iso:std:iec:61970-401:draft:ed-1";
        dcterms:description   "Describing constraints extracted from RDFS.";
        dcterms:identifier    "urn:uuid26c0069f-fdb2-4b0e-98da-b9a9be7bd325";
        dcterms:issued        "2025-10-04T06:59:06.503846300"^^xsd:dateTime;
        dcterms:language      "en-GB";
        dcterms:license       "https://www.apache.org/licenses/LICENSE-2.0"@en;
        dcterms:modified      "2023-05-10"^^xsd:date;
        dcterms:publisher     "ENTSO-E"@en;
        dcterms:rightsHolder  "ENTSO-E"@en;
        dcterms:title         "Document header vocabulary"@en;
        owl:versionIRI    <Constraints/2.2>;
        owl:versionInfo   "2.2.0"@en;
        dcat:keyword      "DH";
        dcat:theme        "constraint"@en .

dh:FullModel-AllowedProperties
        rdf:type              sh:NodeShape;
        sh:closed             true;
        sh:description        "Checks if the dataset contains properties which are not defined in the profile to which this dataset conforms to.";
        sh:group              dh:ProfilePropertiesGroup;
        sh:ignoredProperties  ( rdf:type );
        sh:message            "This property is not part of the profile to which this dataset conforms to.";
        sh:name               "PropertyNotInProfile";
        sh:order              2;
        sh:property           [ sh:path  prov:wasInfluencedBy ];
        sh:property           [ sh:path  <http://purl.org/dc/terms/#type> ];
        sh:property           [ sh:path  md:Model.description ];
        sh:property           [ sh:path  prov:wasGeneratedBy ];
        sh:property           [ sh:path  eumd:Model.processType ];
        sh:property           [ sh:path  prov:wasRevisionOf ];
        sh:property           [ sh:path  euvoc:status ];
        sh:property           [ sh:path  prov:generatedAtTime ];
        sh:property           [ sh:path  dcat:endDate ];
        sh:property           [ sh:path  adms:versionNotes ];
        sh:property           [ sh:path  md:Model.created ];
        sh:property           [ sh:path  md:Model.profile ];
        sh:property           [ sh:path  <http://purl.org/dc/terms/#creator> ];
        sh:property           [ sh:path  md:Model.DependentOn ];
        sh:property           [ sh:path  dcat:isVersionOf ];
        sh:property           [ sh:path  <http://purl.org/dc/terms/#license> ];
        sh:property           [ sh:path  <http://purl.org/dc/terms/#accessRights> ];
        sh:property           [ sh:path  dcat:previousVersion ];
        sh:property           [ sh:path  md:Model.Supersedes ];
        sh:property           [ sh:path  eumd:Model.usedSettings ];
        sh:property           [ sh:path  prov:specializationOf ];
        sh:property           [ sh:path  md:Model.scenarioTime ];
        sh:property           [ sh:path  prov:wasAttributedTo ];
        sh:property           [ sh:path  dcat:startDate ];
        sh:property           [ sh:path  prov:atLocation ];
        sh:property           [ sh:path  dcat:version ];
        sh:property           [ sh:path  <http://purl.org/dc/terms/#source> ];
        sh:property           [ sh:path  prov:hadPrimarySource ];
        sh:property           [ sh:path  dcat:hasCurrentVersion ];
        sh:property           [ sh:path  <http://purl.org/dc/terms/#identifier> ];
        sh:property           [ sh:path  eumd:Model.serviceLocation ];
        sh:property           [ sh:path  dcat:keyword ];
        sh:property           [ sh:path  <http://purl.org/dc/terms/#accrualPeriodicity> ];
        sh:property           [ sh:path  <http://purl.org/dc/terms/#rightsHolder> ];
        sh:property           [ sh:path  dcat:hasVersion ];
        sh:property           [ sh:path  md:Model.modelingAuthoritySet ];
        sh:property           [ sh:path  md:Model.version ];
        sh:property           [ sh:path  eumd:Model.applicationSoftware ];
        sh:property           [ sh:path  <http://purl.org/dc/terms/#rights> ];
        sh:property           [ sh:path  <http://purl.org/dc/terms/#conformsTo> ];
        sh:property           [ sh:path  <http://purl.org/dc/terms/#description> ];
        sh:severity           sh:Info;
        sh:targetClass        md:FullModel .

dh:FullModel  rdf:type  sh:NodeShape;
        sh:property     dh:wasInfluencedBy-datatype , dh:type-datatype , dh:type-cardinality , dh:Model.description-datatype , dh:Model.description-cardinality , dh:wasGeneratedBy-datatype , dh:Model.processType-datatype , dh:Model.processType-cardinality , dh:wasRevisionOf-datatype , dh:status-datatype , dh:status-cardinality , dh:generatedAtTime-datatype , dh:generatedAtTime-cardinality , dh:endDate-datatype , dh:endDate-cardinality , dh:versionNotes-datatype , dh:versionNotes-cardinality , dh:Model.created-datatype , dh:Model.created-cardinality , dh:Model.profile-datatype , dh:creator-datatype , dh:creator-cardinality , dh:isVersionOf-datatype , dh:isVersionOf-cardinality , dh:license-datatype , dh:license-cardinality , dh:accessRights-datatype , dh:accessRights-cardinality , dh:previousVersion-datatype , dh:previousVersion-cardinality , dh:Model.usedSettings-datatype , dh:specializationOf-datatype , dh:Model.scenarioTime-datatype , dh:Model.scenarioTime-cardinality , dh:wasAttributedTo-datatype , dh:startDate-datatype , dh:startDate-cardinality , dh:atLocation-datatype , dh:atLocation-cardinality , dh:version-datatype , dh:version-cardinality , dh:source-datatype , dh:source-cardinality , dh:description-datatype , dh:description-cardinality , dh:conformsTo-datatype , dh:rights-datatype , dh:rights-cardinality , dh:Model.applicationSoftware-datatype , dh:Model.applicationSoftware-cardinality , dh:Model.version-datatype , dh:Model.version-cardinality , dh:Model.modelingAuthoritySet-datatype , dh:Model.modelingAuthoritySet-cardinality , dh:hasVersion-datatype , dh:hadPrimarySource-datatype , dh:hasCurrentVersion-cardinality , dh:hasCurrentVersion-datatype , dh:identifier-cardinality , dh:identifier-datatype , dh:Model.serviceLocation-cardinality , dh:Model.serviceLocation-datatype , dh:keyword-cardinality , dh:keyword-datatype , dh:accrualPeriodicity-cardinality , dh:accrualPeriodicity-datatype , dh:rightsHolder-cardinality , dh:rightsHolder-datatype , dh:hasVersion-cardinality;
        sh:targetClass  md:FullModel .

dh:Model.Depending-propertyInverse
        rdf:type        sh:PropertyShape;
        sh:description  "Inverse associations shall not be instantiated.";
        sh:group        dh:InverseAssociationsGroup;
        sh:maxCount     0;
        sh:message      "Inverse association is present.";
        sh:name         "InverseAssociationPresent";
        sh:order        2;
        sh:path         md:Model.Depending;
        sh:severity     sh:Violation .

dh:Model.Depending-inverseNodePresent
        rdf:type             sh:NodeShape;
        sh:property          dh:Model.Depending-propertyInverse;
        sh:targetSubjectsOf  md:Model.Depending .

