dh:DifferenceModel  rdf:type  sh:NodeShape;
        sh:property     dh:wasInfluencedBy-datatype , dh:type-datatype , dh:type-cardinality , dh:Model.description-datatype , dh:Model.description-cardinality , dh:wasGeneratedBy-datatype , dh:Model.processType-datatype , dh:Model.processType-cardinality , dh:wasRevisionOf-datatype , dh:status-datatype , dh:status-cardinality , dh:generatedAtTime-datatype , dh:generatedAtTime-cardinality , dh:endDate-datatype , dh:endDate-cardinality , dh:versionNotes-datatype , dh:versionNotes-cardinality , dh:Model.created-datatype , dh:Model.created-cardinality , dh:Model.profile-datatype , dh:creator-datatype , dh:creator-cardinality , dh:isVersionOf-datatype , dh:isVersionOf-cardinality , dh:license-datatype , dh:license-cardinality , dh:accessRights-datatype , dh:accessRights-cardinality , dh:previousVersion-datatype , dh:previousVersion-cardinality , dh:Model.usedSettings-datatype , dh:specializationOf-datatype , dh:Model.scenarioTime-datatype , dh:Model.scenarioTime-cardinality , dh:wasAttributedTo-datatype , dh:startDate-datatype , dh:startDate-cardinality , dh:atLocation-datatype , dh:atLocation-cardinality , dh:version-datatype , dh:version-cardinality , dh:source-datatype , dh:source-cardinality , dh:description-datatype , dh:description-cardinality , dh:conformsTo-datatype , dh:rights-datatype , dh:rights-cardinality , dh:Model.applicationSoftware-datatype , dh:Model.applicationSoftware-cardinality , dh:Model.version-datatype , dh:Model.version-cardinality , dh:Model.modelingAuthoritySet-datatype , dh:Model.modelingAuthoritySet-cardinality , dh:hasVersion-datatype , dh:hasVersion-cardinality , dh:rightsHolder-datatype , dh:rightsHolder-cardinality , dh:accrualPeriodicity-datatype , dh:accrualPeriodicity-cardinality , dh:keyword-datatype , dh:keyword-cardinality , dh:Model.serviceLocation-datatype , dh:Model.serviceLocation-cardinality , dh:identifier-datatype , dh:identifier-cardinality , dh:hasCurrentVersion-datatype , dh:DifferenceModel.forwardDifferences-cardinality , dh:DifferenceModel.forwardDifferences-datatype , dh:Statement.object-cardinality , dh:Statement.object-datatype , dh:Statement.predicate-cardinality , dh:Statement.predicate-datatype , dh:Statement.subject-cardinality , dh:Statement.subject-datatype , dh:DifferenceModel.reverseDifferences-cardinality , dh:DifferenceModel.reverseDifferences-datatype , dh:DifferenceModel.preconditions-cardinality , dh:DifferenceModel.preconditions-datatype , dh:hadPrimarySource-datatype , dh:hasCurrentVersion-cardinality;
        sh:targetClass  dm:DifferenceModel .

cc:     rdf:type     owl:Ontology;
        owl:imports  sh:;
        sh:declare   [ rdf:type      sh:PrefixDeclaration;
                       sh:namespace  "http://www.w3.org/1999/02/22-rdf-syntax-ns#";
                       sh:prefix     "rdf"
                     ] .

cc:ClassCount-propertySparql
        rdf:type     sh:SPARQLConstraint;
        sh:message   "The class {?class} appears {?value} times in the data graph.";
        sh:prefixes  cc:;
        sh:select    """ 
            SELECT $this ?class (COUNT(?instance) AS ?value)
            WHERE {
                    ?instance rdf:type ?class .
                   }
            GROUP BY $this ?class
             """ .

cc:ClassCount-property
        rdf:type        sh:PropertyShape;
        sh:description  "Counts instance of classes present in the data graph.";
        sh:group        cc:ClassesCountGroup;
        sh:name         "ClassCount";
        sh:order        1;
        sh:path         rdf:type;
        sh:severity     sh:Info;
        sh:sparql       cc:ClassCount-propertySparql .

cc:ClassCount-node  rdf:type  sh:NodeShape;
        sh:property    cc:ClassCount-property;
        sh:targetClass  dcat:Dataset, md:FullModel .

cc:ClassesCountGroup  rdf:type  sh:PropertyGroup;
        rdfs:label  "ClassesCount";
        sh:order    1 .

