        sh:name         "FaultCause.mRID-cardinality";
        sh:order        77;
        sh:path         nc:FaultCause.mRID;
        sh:severity     sh:Violation .

gd:FaultCause.FaultCauseType-valueType
        rdf:type        sh:PropertyShape;
        sh:class        cim:FaultCauseType;
        sh:description  "This constraint validates the value of the association at the used direction.";
        sh:group        gd:AssociationsGroup;
