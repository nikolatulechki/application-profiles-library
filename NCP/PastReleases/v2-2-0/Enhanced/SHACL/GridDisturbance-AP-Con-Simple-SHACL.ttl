        sh:group        gd:ProfileClassesGroup;
        sh:in           ( cim:Equipment cim:DCBusbar cim16:DCSeriesDevice cim16:DCBusbar cim:DCShunt cim16:DCChopper cim16:DCShunt cim16:DCLineSegment cim16:DCGround cim16:DCSwitch cim16:DCBreaker cim:DCBreaker cim16:DCDisconnector cim:DCDisconnector cim:DCSeriesDevice cim:DCGround cim:DCChopper cim:DCLineSegment cim:DCSwitch cim:HydroPump cim16:HydroPump cim:GeneratingUnit cim:WindGeneratingUnit cim16:NuclearGeneratingUnit cim16:HydroGeneratingUnit cim16:SolarGeneratingUnit cim16:ThermalGeneratingUnit nc:GeothermalGeneratingUnit cim16:WindGeneratingUnit cim:HydroGeneratingUnit cim:ThermalGeneratingUnit cim:SolarGeneratingUnit cim:NuclearGeneratingUnit cim16:GeneratingUnit cim16:PowerTransformer cim:EquivalentInjection cim16:EquivalentBranch cim16:EquivalentShunt cim16:EquivalentInjection cim:EquivalentShunt cim:EquivalentBranch cim16:EnergyConsumer cim16:ConformLoad cim:NonConformLoad cim:StationSupply cim16:StationSupply cim16:NonConformLoad cim:ConformLoad cim:Switch cim:LoadBreakSwitch cim16:LoadBreakSwitch cim:Breaker cim:DisconnectingCircuitBreaker cim16:Breaker cim:GroundDisconnector cim16:GroundDisconnector cim:Jumper cim16:Disconnector cim:Fuse cim:Cut cim:Disconnector cim16:StaticVarCompensator cim:PowerElectronicsConnection cim16:NonlinearShuntCompensator cim:LinearShuntCompensator cim16:LinearShuntCompensator cim:NonlinearShuntCompensator cim:AsynchronousMachine cim:SynchronousMachine cim16:AsynchronousMachine cim16:SynchronousMachine nc:StaticSynchronousCompensator nc:ThyristorControlledSeriesCompensator nc:ModularStaticSynchronousSeriesCompensator nc:StaticVarCompensator nc:StaticSynchronousSeriesCompensator cim:StaticVarCompensator cim16:ExternalNetworkInjection cim:ExternalNetworkInjection cim:EnergySource cim:EnergyConsumer cim:Clamp cim:BusbarSection cim16:BusbarSection cim16:Junction cim:Junction cim16:PetersenCoil cim:GroundingImpedance cim:PetersenCoil cim16:GroundingImpedance cim:ACLineSegment cim16:ACLineSegment cim:ACDCConverter cim16:CsConverter cim16:VsConverter cim:VsConverter cim:CsConverter cim:SeriesCompensator cim:Ground cim16:Ground cim16:EnergySource cim16:Switch cim:PowerTransformer cim16:SeriesCompensator cim:PowerElectronicsUnit nc:ChargingUnit cim:PhotoVoltaicUnit nc:FlexibleEnergyUnit cim:PowerElectronicsWindUnit nc:PowerElectronicsMarineUnit cim:BatteryUnit nc:PowerElectricalChemicalUnit cim:WaveTrap cim:PotentialTransformer cim:PostLineSensor cim:CurrentTransformer cim:FaultIndicator cim:SurgeArrester cim:CoordinateSystem cim:Fault nc:FaultOutage cim:Location nc:GridDisturbance cim:PositionPoint nc:Interruption cim:UnplannedOutage cim:FaultCauseType nc:FaultCause md:FullModel dm:DifferenceModel dcat:Dataset );
