gd:FaultCause.Fault-valueType
        rdf:type        sh:PropertyShape;
        sh:class        cim:Fault;
        sh:description  "This constraint validates the value of the association at the used direction.";
        sh:group        gd:AssociationsGroup;
        sh:message      "One of the following does not conform: 1) The value shall be IRI; 2) The value shall be an instance of the class: cim17:Fault";
        sh:name         "FaultCause.Fault-valueType";
        sh:nodeKind     sh:IRI;
        sh:order        15;
        sh:path         nc:FaultCause.Fault;
        sh:severity     sh:Violation .

gd:FaultCause.Fault-cardinality
        rdf:type        sh:PropertyShape;
        sh:description  "This constraint validates the cardinality of the association at the used direction.";
        sh:group        gd:CardinalityGroup;
        sh:maxCount     1;
        sh:message      "Association with cardinality violation at the used direction.";
        sh:minCount     1;
        sh:name         "FaultCause.Fault-cardinality";
        sh:order        79;
        sh:path         nc:FaultCause.Fault;
        sh:severity     sh:Violation .

gd:FaultCause.certaintyLevel-datatype
        rdf:type        sh:PropertyShape;
        sh:description  "This constraint validates the datatype of the property (attribute).";
        sh:group        gd:DatatypesGroup;
        sh:in           ( nc:CertaintyLevelKind.medium nc:CertaintyLevelKind.low nc:CertaintyLevelKind.high nc:CertaintyLevelKind.none );
        sh:message      "The datatype is not IRI (Internationalized Resource Identifier) or it is enumerated value not part of the profile.";
        sh:name         "FaultCause.certaintyLevel-datatype";
        sh:nodeKind     sh:IRI;
        sh:order        49;
        sh:path         nc:FaultCause.certaintyLevel;
        sh:severity     sh:Violation .

gd:FaultCause.certaintyLevel-cardinality
        rdf:type        sh:PropertyShape;
        sh:description  "This constraint validates the cardinality of the property (attribute).";
        sh:group        gd:CardinalityGroup;
        sh:maxCount     1;
        sh:message      "Missing required property (attribute).";
        sh:minCount     1;
        sh:name         "FaultCause.certaintyLevel-cardinality";
        sh:order        78;
        sh:path         nc:FaultCause.certaintyLevel;
        sh:severity     sh:Violation .

gd:FaultCause.mRID-datatype
        rdf:type        sh:PropertyShape;
