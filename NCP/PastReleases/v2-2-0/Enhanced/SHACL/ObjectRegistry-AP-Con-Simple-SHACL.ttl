or:Ontology  rdf:type     owl:Ontology;
        dcterms:conformsTo    "urn:iso:std:iec:61970-401:draft:ed-1" , "urn:iso:std:iec:61970-501:draft:ed-2" , "file://CGMES-30v25_501-20v01.eap" , "urn:iso:std:iec:61970-600-2:ed-1" , "file://iec61970cim17v40_iec61968cim13v13a_iec62325cim03v17a.eap" , "urn:iso:std:iec:61970-301:ed-7:amd1";
        dcterms:description   "Describing constraints extracted from RDFS.";
        dcterms:identifier    "urn:uuid4a05d581-a5c5-439b-ac37-5843596362c8";
        dcterms:issued        "2025-10-04T07:00:33.377767900"^^xsd:dateTime;
        dcterms:language      "en-GB";
        dcterms:license       "https://www.apache.org/licenses/LICENSE-2.0"@en;
        dcterms:modified      "2022-12-29"^^xsd:date;
        dcterms:publisher     "ENTSO-E"@en;
        dcterms:rightsHolder  "ENTSO-E"@en;
        dcterms:title         "Object Registry vocabulary"@en;
