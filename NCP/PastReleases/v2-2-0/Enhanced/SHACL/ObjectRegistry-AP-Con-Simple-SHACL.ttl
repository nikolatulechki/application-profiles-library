        sh:path         nc:Name.mRID;
        sh:severity     sh:Violation .

or:Name.NameType-valueType
        rdf:type        sh:PropertyShape;
        sh:class        cim:NameType;
        sh:description  "This constraint validates the value of the association at the used direction.";
        sh:group        or:AssociationsGroup;
        sh:message      "One of the following does not conform: 1) The value shall be IRI; 2) The value shall be an instance of the class: cim17:NameType";
        sh:name         "Name.NameType-valueType";
        sh:nodeKind     sh:IRI;
        sh:order        4;
        sh:path         nc:Name.NameType;
