        owl:versionInfo   "2.1.0"@en;
        dcat:keyword      "OR";
        dcat:theme        "constraint"@en .

or:NameType.Name-propertyInverse
        rdf:type        sh:PropertyShape;
        sh:description  "Inverse associations shall not be instantiated.";
        sh:group        or:InverseAssociationsGroup;
        sh:maxCount     0;
        sh:message      "Inverse association is present.";
        sh:name         "InverseAssociationPresent";
        sh:order        4;
        sh:path         nc:NameType.Name;
        sh:severity     sh:Violation .

or:NameType.Name-inverseNodePresent
        rdf:type             sh:NodeShape;
        sh:property          or:NameType.Name-propertyInverse;
        sh:targetSubjectsOf  nc:NameType.Name .

or:NameType.name-datatype
        rdf:type        sh:PropertyShape;
        sh:datatype     xsd:string;
        sh:description  "This constraint validates the datatype of the property (attribute).";
        sh:group        or:DatatypesGroup;
        sh:message      "The datatype is not literal or it violates the xsd datatype.";
        sh:name         "NameType.name-datatype";
        sh:nodeKind     sh:Literal;
        sh:order        8;
        sh:path         cim:NameType.name;
        sh:severity     sh:Violation .

or:NameType.name-cardinality
        rdf:type        sh:PropertyShape;
        sh:description  "This constraint validates the cardinality of the property (attribute).";
        sh:group        or:CardinalityGroup;
        sh:maxCount     1;
        sh:message      "Missing required property (attribute).";
        sh:minCount     1;
        sh:name         "NameType.name-cardinality";
        sh:order        18;
        sh:path         cim:NameType.name;
        sh:severity     sh:Violation .

or:NameType.description-datatype
        rdf:type        sh:PropertyShape;
        sh:datatype     xsd:string;
        sh:description  "This constraint validates the datatype of the property (attribute).";
        sh:group        or:DatatypesGroup;
        sh:message      "The datatype is not literal or it violates the xsd datatype.";
        sh:name         "NameType.description-datatype";
        sh:nodeKind     sh:Literal;
        sh:order        7;
        sh:path         cim:NameType.description;
        sh:severity     sh:Violation .

or:NameType.description-cardinality
        rdf:type        sh:PropertyShape;
        sh:description  "This constraint validates the cardinality of the property (attribute).";
        sh:group        or:CardinalityGroup;
        sh:maxCount     1;
        sh:message      "Cardinality violation. Upper bound shall be 1";
        sh:name         "NameType.description-cardinality";
        sh:order        17;
        sh:path         cim:NameType.description;
        sh:severity     sh:Violation .

or:NameType.mRID-datatype
        rdf:type        sh:PropertyShape;
        sh:datatype     xsd:string;
        sh:description  "This constraint validates the datatype of the property (attribute).";
        sh:group        or:DatatypesGroup;
        sh:message      "The datatype is not literal or it violates the xsd datatype.";
        sh:name         "NameType.mRID-datatype";
        sh:nodeKind     sh:Literal;
        sh:order        6;
        sh:path         nc:NameType.mRID;
        sh:severity     sh:Violation .

or:NameType.mRID-cardinality
        rdf:type        sh:PropertyShape;
        sh:description  "This constraint validates the cardinality of the property (attribute).";
        sh:group        or:CardinalityGroup;
        sh:maxCount     1;
        sh:message      "Missing required property (attribute).";
        sh:minCount     1;
        sh:name         "NameType.mRID-cardinality";
        sh:order        16;
        sh:path         nc:NameType.mRID;
        sh:severity     sh:Violation .

or:NameType.NamingAuthority-valueType
        rdf:type        sh:PropertyShape;
        sh:class        nc:NamingAuthority;
        sh:description  "This constraint validates the value of the association at the used direction.";
        sh:group        or:AssociationsGroup;
        sh:message      "One of the following does not conform: 1) The value shall be IRI; 2) The value shall be an instance of the class: nc:NamingAuthority";
        sh:name         "NameType.NamingAuthority-valueType";
        sh:nodeKind     sh:IRI;
        sh:order        5;
        sh:path         nc:NameType.NamingAuthority;
        sh:severity     sh:Violation .

or:NameType.NamingAuthority-cardinality
        rdf:type        sh:PropertyShape;
        sh:description  "This constraint validates the cardinality of the association at the used direction.";
        sh:group        or:CardinalityGroup;
        sh:maxCount     1;
        sh:message      "Cardinality violation. Upper bound shall be 1";
        sh:name         "NameType.NamingAuthority-cardinality";
        sh:order        15;
        sh:path         nc:NameType.NamingAuthority;
        sh:severity     sh:Violation .

or:NameType-AllowedProperties
        rdf:type              sh:NodeShape;
        sh:closed             true;
        sh:description        "Checks if the dataset contains properties which are not defined in the profile to which this dataset conforms to.";
        sh:group              or:ProfilePropertiesGroup;
        sh:ignoredProperties  ( rdf:type );
        sh:message            "This property is not part of the profile to which this dataset conforms to.";
        sh:name               "PropertyNotInProfile";
        sh:order              4;
        sh:property           [ sh:path  cim:NameType.name ];
        sh:property           [ sh:path  cim:NameType.description ];
        sh:property           [ sh:path  nc:NameType.mRID ];
        sh:property           [ sh:path  nc:NameType.NamingAuthority ];
        sh:severity           sh:Info;
        sh:targetClass        cim:NameType .

or:NameType  rdf:type   sh:NodeShape;
        sh:property     or:NameType.name-datatype , or:NameType.name-cardinality , or:NameType.description-datatype , or:NameType.description-cardinality , or:NameType.mRID-datatype , or:NameType.mRID-cardinality , or:NameType.NamingAuthority-valueType , or:NameType.NamingAuthority-cardinality;
        sh:targetClass  cim:NameType .

or:Name.name-datatype
        rdf:type        sh:PropertyShape;
        sh:datatype     xsd:string;
        sh:description  "This constraint validates the datatype of the property (attribute).";
        sh:group        or:DatatypesGroup;
        sh:message      "The datatype is not literal or it violates the xsd datatype.";
