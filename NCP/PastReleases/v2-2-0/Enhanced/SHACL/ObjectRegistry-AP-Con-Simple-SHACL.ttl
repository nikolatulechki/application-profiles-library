6:DiscreteValue cim16:AnalogValue cim16:StringMeasurementValue cim:ValueAliasSet nc:Gate cim16:OperationalLimitType cim:FossilFuel cim16:DCNode cim:LoadResponseCharacteristic cim16:RatioTapChangerTable cim16:ValueToAlias nc:FunctionOutputVariable cim:ContingencyEquipment nc:RemedialActionGroup nc:RedispatchRemedialAction nc:CountertradeRemedialAction nc:AvailabilityRemedialAction nc:SchemeRemedialAction nc:GridStateAlterationRemedialAction cim:EnergySchedulingType nc:Stage cim:ConnectivityNode nc:PTCTriggeredEquipment cim16:ControlAreaGeneratingUnit nc:TriggerCondition nc:VoltageInjectionControlFunction nc:DCVoltageControlFunction nc:PhaseControlFunction nc:ImpedanceControlFunction nc:DCCurrentControlFunction nc:CurrentControlFunction nc:VoltageControlFunction nc:PowerFactorControlFunction nc:ReactivePowerControlFunction nc:CurrentDroopControlFunction nc:ActivePowerControlFunction cim16:MeasurementValueSource nc:StageTrigger cim16:OperationalLimitSet );
        sh:message      "One of the following occurs: 1) The value is not IRI; 2) The value is not the right class.";
        sh:name         "Name.IdentifiedObject-valueType";
        sh:nodeKind     sh:IRI;
        sh:order        3;
        sh:path         ( nc:Name.IdentifiedObject rdf:type );
        sh:severity     sh:Violation .

or:Name.IdentifiedObject-valueTypeNodeShape
        rdf:type        sh:NodeShape;
        sh:property     or:Name.IdentifiedObject-valueType;
        sh:targetClass  cim:Name .

ido:Name.IdentifiedObject-cardinality
        rdf:type        sh:PropertyShape;
        sh:description  "This constraint validates the cardinality of the association at the used direction.";
        sh:group        ido:CardinalityIO;
        sh:maxCount     1;
        sh:message      "Cardinality violation. Upper bound shall be 1";
        sh:name         "Name.IdentifiedObject-cardinality";
        sh:order        0.1;
        sh:path         nc:Name.IdentifiedObject;
        sh:severity     sh:Violation .

