        sh:group        ps:AssociationsGroup;
        sh:in           ( cim:WindGeneratingUnit cim16:NuclearGeneratingUnit cim16:HydroGeneratingUnit cim16:SolarGeneratingUnit cim16:ThermalGeneratingUnit nc:GeothermalGeneratingUnit cim16:WindGeneratingUnit cim:HydroGeneratingUnit cim:ThermalGeneratingUnit cim:SolarGeneratingUnit cim:NuclearGeneratingUnit );
