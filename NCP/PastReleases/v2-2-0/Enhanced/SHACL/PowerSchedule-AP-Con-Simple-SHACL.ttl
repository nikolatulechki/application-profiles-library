ps:MustRunTimePoint-AllowedProperties
        rdf:type              sh:NodeShape;
        sh:closed             true;
        sh:description        "Checks if the dataset contains properties which are not defined in the profile to which this dataset conforms to.";
        sh:group              ps:ProfilePropertiesGroup;
        sh:ignoredProperties  ( rdf:type );
        sh:message            "This property is not part of the profile to which this dataset conforms to.";
        sh:name               "PropertyNotInProfile";
        sh:order              4;
        sh:property           [ sh:path  nc:MustRunTimePoint.MustRunSchedule ];
        sh:property           [ sh:path  nc:MustRunTimePoint.atTime ];
        sh:property           [ sh:path  nc:MustRunTimePoint.mustRun ];
        sh:property           [ sh:path  nc:MustRunTimePoint.minP ];
        sh:property           [ sh:path  nc:MustRunTimePoint.minQ ];
        sh:severity           sh:Info;
        sh:targetClass        nc:MustRunTimePoint .

