        sh:description  "This constraint validates the cardinality of the property (attribute).";
        sh:group        ps:CardinalityGroup;
        sh:maxCount     1;
        sh:message      "Missing required property (attribute).";
        sh:minCount     1;
        sh:name         "MustRunTimePoint.atTime-cardinality";
        sh:order        43;
        sh:path         nc:MustRunTimePoint.atTime;
        sh:severity     sh:Violation .

