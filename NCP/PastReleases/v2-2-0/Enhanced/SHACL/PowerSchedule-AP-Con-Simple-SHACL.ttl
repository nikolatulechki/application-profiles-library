ps:MustRunTimePoint.MustRunSchedule-valueType
        rdf:type        sh:PropertyShape;
        sh:class        nc:MustRunSchedule;
        sh:description  "This constraint validates the value of the association at the used direction.";
        sh:group        ps:AssociationsGroup;
        sh:message      "One of the following does not conform: 1) The value shall be IRI; 2) The value shall be an instance of the class: nc:MustRunSchedule";
        sh:name         "MustRunTimePoint.MustRunSchedule-valueType";
        sh:nodeKind     sh:IRI;
        sh:order        16;
        sh:path         nc:MustRunTimePoint.MustRunSchedule;
        sh:severity     sh:Violation .

ps:MustRunTimePoint.MustRunSchedule-cardinality
        rdf:type        sh:PropertyShape;
        sh:description  "This constraint validates the cardinality of the association at the used direction.";
        sh:group        ps:CardinalityGroup;
        sh:maxCount     1;
        sh:message      "Association with cardinality violation at the used direction.";
        sh:minCount     1;
        sh:name         "MustRunTimePoint.MustRunSchedule-cardinality";
        sh:order        44;
        sh:path         nc:MustRunTimePoint.MustRunSchedule;
        sh:severity     sh:Violation .

ps:MustRunTimePoint.atTime-datatype
        rdf:type        sh:PropertyShape;
