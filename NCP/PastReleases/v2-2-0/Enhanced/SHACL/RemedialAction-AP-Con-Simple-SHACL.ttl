cc:     rdf:type     owl:Ontology;
        owl:imports  sh:;
        sh:declare   [ rdf:type      sh:PrefixDeclaration;
                       sh:namespace  "http://www.w3.org/1999/02/22-rdf-syntax-ns#";
                       sh:prefix     "rdf"
                     ] .

cc:ClassCount-propertySparql
        rdf:type     sh:SPARQLConstraint;
        sh:message   "The class {?class} appears {?value} times in the data graph.";
        sh:prefixes  cc:;
        sh:select    """ 
            SELECT $this ?class (COUNT(?instance) AS ?value)
            WHERE {
                    ?instance rdf:type ?class .
                   }
            GROUP BY $this ?class
             """ .

cc:ClassCount-property
        rdf:type        sh:PropertyShape;
        sh:description  "Counts instance of classes present in the data graph.";
        sh:group        cc:ClassesCountGroup;
        sh:name         "ClassCount";
        sh:order        1;
        sh:path         rdf:type;
        sh:severity     sh:Info;
        sh:sparql       cc:ClassCount-propertySparql .

cc:ClassCount-node  rdf:type  sh:NodeShape;
        sh:property    cc:ClassCount-property;
        sh:targetClass  dcat:Dataset, md:FullModel .

cc:ClassesCountGroup  rdf:type  sh:PropertyGroup;
        rdfs:label  "ClassesCount";
        sh:order    1 .

ra:AllowedClasses-property
        rdf:type        sh:PropertyShape;
        sh:description  "Checks if the dataset contains classes which are not defined in the profile to which this dataset conforms to.";
        sh:group        ra:ProfileClassesGroup;
        sh:in           ( nc:TapPositionAction nc:RegulatingControlAction nc:EnergySourceModification nc:BiddingZoneAction nc:LoadAction nc:RotatingMachineAction nc:PowerElectronicsConnectionAction nc:EquivalentInjectionAction nc:ControlFunctionBlockAction nc:BatteryUnitAction nc:ExternalNetworkInjectionAction nc:ShuntCompensatorModification nc:ACDCConverterAction nc:StaticVarCompensatorAction nc:EquipmentControllerAction nc:TopologyAction nc:Gate nc:AvailabilityRemedialAction nc:PinTerminal nc:GridStateAlterationCollection nc:GridStateAlterationRemedialAction cim:Substation nc:PinMeasurement nc:MeasurementCalculatorInput nc:RemedialActionDependency nc:IntertemporalPropertyRange nc:TriggerCondition nc:RemedialActionScheme nc:PinPowerTransferCorridor nc:PinContingency nc:PinTerminalLimit nc:PinEquipment nc:PinEquipmentTripping nc:PinGate nc:PinDCTerminal nc:StaticPropertyRange nc:CountertradeRemedialAction nc:StageTrigger nc:RedispatchRemedialAction nc:SchemeRemedialAction nc:Stage cim:GeneratingUnit cim:WindGeneratingUnit cim16:NuclearGeneratingUnit cim16:HydroGeneratingUnit cim16:SolarGeneratingUnit cim16:ThermalGeneratingUnit nc:GeothermalGeneratingUnit cim16:WindGeneratingUnit cim:HydroGeneratingUnit cim:ThermalGeneratingUnit cim:SolarGeneratingUnit cim:NuclearGeneratingUnit nc:ContingencyWithRemedialAction nc:RemedialActionGroup nc:SolarRadiationDependencyCurve nc:MeasurementCalculator nc:ExceptionalPowerTransferCorridor nc:OrdinaryPowerTransferCorridor nc:PTCActivePowerSupport cim:Line md:FullModel dm:DifferenceModel dcat:Dataset );
        sh:message      "This class is not part of the profile to which this dataset conforms to.";
        sh:name         "ClassNotInProfile";
        sh:order        1;
        sh:path         rdf:type;
        sh:severity     sh:Info .

ra:AllowedClasses-node
        rdf:type             sh:NodeShape;
        sh:property          ra:AllowedClasses-property;
        sh:targetSubjectsOf  rdf:type .

