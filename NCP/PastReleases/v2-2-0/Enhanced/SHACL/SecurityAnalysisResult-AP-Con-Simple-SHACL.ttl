sar:Ontology  rdf:type    owl:Ontology;
        dcterms:conformsTo    "file://iec61970cim17v40_iec61968cim13v13a_iec62325cim03v17a.eap" , "urn:iso:std:iec:61970-600-2:ed-1" , "file://CGMES-30v25_501-20v01.eap" , "urn:iso:std:iec:61970-301:ed-7:amd1" , "urn:iso:std:iec:61970-401:draft:ed-1" , "urn:iso:std:iec:61970-501:draft:ed-2";
        dcterms:description   "Describing constraints extracted from RDFS.";
        dcterms:identifier    "urn:uuid011c9228-47b3-4bd5-8fd5-16620a6e08c9";
        dcterms:issued        "2025-10-04T07:01:55.787609900"^^xsd:dateTime;
        dcterms:language      "en-GB";
        dcterms:license       "https://www.apache.org/licenses/LICENSE-2.0"@en;
        dcterms:modified      "2023-04-20"^^xsd:date;
        dcterms:publisher     "ENTSO-E"@en;
        dcterms:rightsHolder  "ENTSO-E"@en;
        dcterms:title         "Security Analysis Result Vocabulary"@en;
        owl:versionIRI    <Constraints/2.2>;
        owl:versionInfo   "2.2.0"@en;
        dcat:keyword      "SAR";
        dcat:theme        "constraint"@en .

sar:ContingencyPowerFlowResult.Contingency-valueType
        rdf:type        sh:PropertyShape;
        sh:description  "This constraint validates the value of the association at the used direction.";
        sh:group        sar:AssociationsGroup;
        sh:in           ( nc:OutOfRangeContingency nc:ExceptionalContingency nc:OrdinaryContingency );
        sh:message      "One of the following occurs: 1) The value is not IRI; 2) The value is not the right class.";
        sh:name         "ContingencyPowerFlowResult.Contingency-valueType";
        sh:nodeKind     sh:IRI;
        sh:order        4;
        sh:path         ( nc:ContingencyPowerFlowResult.Contingency rdf:type );
        sh:severity     sh:Violation .

sar:ContingencyPowerFlowResult.Contingency-valueTypeNodeShape
        rdf:type        sh:NodeShape;
        sh:property     sar:ContingencyPowerFlowResult.Contingency-valueType;
        sh:targetClass  nc:ContingencyPowerFlowResult .

sar:ContingencyPowerFlowResult.Contingency-cardinality
        rdf:type        sh:PropertyShape;
        sh:description  "This constraint validates the cardinality of the association at the used direction.";
        sh:group        sar:CardinalityGroup;
        sh:maxCount     1;
        sh:message      "Association with cardinality violation at the used direction.";
        sh:minCount     1;
        sh:name         "ContingencyPowerFlowResult.Contingency-cardinality";
        sh:order        14;
        sh:path         nc:ContingencyPowerFlowResult.Contingency;
        sh:severity     sh:Violation .

sar:ContingencyPowerFlowResult-AllowedProperties
        rdf:type              sh:NodeShape;
        sh:closed             true;
        sh:description        "Checks if the dataset contains properties which are not defined in the profile to which this dataset conforms to.";
        sh:group              sar:ProfilePropertiesGroup;
        sh:ignoredProperties  ( rdf:type );
        sh:message            "This property is not part of the profile to which this dataset conforms to.";
        sh:name               "PropertyNotInProfile";
        sh:order              2;
        sh:property           [ sh:path  nc:ContingencyPowerFlowResult.Contingency ];
        sh:property           [ sh:path  nc:PowerFlowResult.ReportedByRegion ];
        sh:property           [ sh:path  nc:PowerFlowResult.valueVAR ];
        sh:property           [ sh:path  nc:PowerFlowResult.absoluteValue ];
        sh:property           [ sh:path  nc:PowerFlowResult.atTime ];
        sh:property           [ sh:path  nc:PowerFlowResult.OperationalLimit ];
        sh:property           [ sh:path  nc:PowerFlowResult.valueVA ];
        sh:property           [ sh:path  nc:PowerFlowResult.isViolation ];
        sh:property           [ sh:path  nc:PowerFlowResult.value ];
        sh:property           [ sh:path  nc:PowerFlowResult.valueW ];
        sh:property           [ sh:path  nc:PowerFlowResult.valueV ];
        sh:property           [ sh:path  nc:PowerFlowResult.ACDCTerminal ];
        sh:property           [ sh:path  nc:PowerFlowResult.valueAngle ];
        sh:property           [ sh:path  nc:PowerFlowResult.valueA ];
        sh:severity           sh:Info;
        sh:targetClass        nc:ContingencyPowerFlowResult .

sar:ContingencyPowerFlowResult
        rdf:type        sh:NodeShape;
        sh:property     sar:PowerFlowResult.valueA-datatype , sar:PowerFlowResult.valueA-cardinality , sar:PowerFlowResult.valueAngle-datatype , sar:PowerFlowResult.valueAngle-cardinality , sar:PowerFlowResult.ACDCTerminal-cardinality , sar:PowerFlowResult.valueV-datatype , sar:PowerFlowResult.valueV-cardinality , sar:PowerFlowResult.valueW-datatype , sar:PowerFlowResult.valueW-cardinality , sar:PowerFlowResult.value-datatype , sar:ContingencyPowerFlowResult.Contingency-cardinality , sar:PowerFlowResult.ReportedByRegion-cardinality , sar:PowerFlowResult.valueVAR-cardinality , sar:PowerFlowResult.valueVAR-datatype , sar:PowerFlowResult.absoluteValue-cardinality , sar:PowerFlowResult.absoluteValue-datatype , sar:PowerFlowResult.atTime-cardinality , sar:PowerFlowResult.atTime-datatype , sar:PowerFlowResult.OperationalLimit-cardinality , sar:PowerFlowResult.valueVA-cardinality , sar:PowerFlowResult.valueVA-datatype , sar:PowerFlowResult.isViolation-cardinality , sar:PowerFlowResult.isViolation-datatype , sar:PowerFlowResult.value-cardinality;
        sh:targetClass  nc:ContingencyPowerFlowResult .

