        sh:group        sm:CardinalityGroup;
        sh:maxCount     1;
        sh:message      "Missing required property (attribute).";
        sh:minCount     1;
        sh:name         "SensitivityMatrix.kind-cardinality";
        sh:order        1;
        sh:path         nc:SensitivityMatrix.kind;
        sh:severity     sh:Violation .

sm:SensitivityMatrix-AllowedProperties
        rdf:type              sh:NodeShape;
        sh:closed             true;
        sh:description        "Checks if the dataset contains properties which are not defined in the profile to which this dataset conforms to.";
        sh:group              sm:ProfilePropertiesGroup;
        sh:ignoredProperties  ( rdf:type );
        sh:message            "This property is not part of the profile to which this dataset conforms to.";
        sh:name               "PropertyNotInProfile";
        sh:order              1;
        sh:property           [ sh:path  cim:IdentifiedObject.description ];
        sh:property           [ sh:path  cim:IdentifiedObject.mRID ];
        sh:property           [ sh:path  cim:IdentifiedObject.name ];
        sh:property           [ sh:path  nc:SensitivityMatrix.kind ];
        sh:severity           sh:Info;
        sh:targetClass        nc:SensitivityMatrix .

sm:SensitivityMatrix  rdf:type  sh:NodeShape;
        sh:property     ido:IdentifiedObject.description-datatype , ido:IdentifiedObject.description-cardinality , ido:IdentifiedObject.mRID-datatype , ido:IdentifiedObject.mRID-cardinality , ido:IdentifiedObject.name-datatype , ido:IdentifiedObject.name-cardinality , sm:SensitivityMatrix.SensitivityFactor-cardinality , sm:SensitivityMatrix.kind-datatype , sm:SensitivityMatrix.kind-cardinality;
        sh:targetClass  nc:SensitivityMatrix .

cc:     rdf:type     owl:Ontology;
        owl:imports  sh:;
        sh:declare   [ rdf:type      sh:PrefixDeclaration;
                       sh:namespace  "http://www.w3.org/1999/02/22-rdf-syntax-ns#";
                       sh:prefix     "rdf"
                     ] .

cc:ClassCount-propertySparql
        rdf:type     sh:SPARQLConstraint;
        sh:message   "The class {?class} appears {?value} times in the data graph.";
        sh:prefixes  cc:;
        sh:select    """ 
            SELECT $this ?class (COUNT(?instance) AS ?value)
            WHERE {
                    ?instance rdf:type ?class .
                   }
            GROUP BY $this ?class
             """ .

cc:ClassCount-property
        rdf:type        sh:PropertyShape;
        sh:description  "Counts instance of classes present in the data graph.";
        sh:group        cc:ClassesCountGroup;
        sh:name         "ClassCount";
        sh:order        1;
        sh:path         rdf:type;
        sh:severity     sh:Info;
        sh:sparql       cc:ClassCount-propertySparql .

cc:ClassCount-node  rdf:type  sh:NodeShape;
        sh:property    cc:ClassCount-property;
        sh:targetClass  dcat:Dataset, md:FullModel .

cc:ClassesCountGroup  rdf:type  sh:PropertyGroup;
        rdfs:label  "ClassesCount";
        sh:order    1 .

sm:AllowedClasses-property
        rdf:type        sh:PropertyShape;
        sh:description  "Checks if the dataset contains classes which are not defined in the profile to which this dataset conforms to.";
        sh:group        sm:ProfileClassesGroup;
        sh:in           ( nc:SensitivityMatrix nc:ControllableQuantity nc:SensitivityFactor nc:ObservableQuantity md:FullModel dm:DifferenceModel dcat:Dataset );
        sh:message      "This class is not part of the profile to which this dataset conforms to.";
        sh:name         "ClassNotInProfile";
        sh:order        1;
        sh:path         rdf:type;
        sh:severity     sh:Info .

sm:AllowedClasses-node
        rdf:type             sh:NodeShape;
        sh:property          sm:AllowedClasses-property;
        sh:targetSubjectsOf  rdf:type .

sm:ProfilePropertiesGroup
        rdf:type    sh:PropertyGroup;
        rdfs:label  "ProfileProperties";
        sh:order    1 .

sm:AssociationsGroup  rdf:type  sh:PropertyGroup;
        rdfs:label  "Associations";
        sh:order    2 .

ido:DatatypesGroupIO  rdf:type  sh:PropertyGroup;
        rdfs:label  "DatatypesIO";
        sh:order    1 .

sm:ProfileClassesGroup
        rdf:type    sh:PropertyGroup;
        rdfs:label  "ProfileClasses";
        sh:order    1 .

sm:InverseAssociationsGroup
        rdf:type    sh:PropertyGroup;
        rdfs:label  "InverseAssociations";
        sh:order    1 .

sm:DatatypesGroup  rdf:type  sh:PropertyGroup;
        rdfs:label  "Datatypes";
        sh:order    1 .

ido:CardinalityGroup  rdf:type  sh:PropertyGroup;
        rdfs:label  "CardinalityIO";
        sh:order    0 .

sm:CardinalityGroup  rdf:type  sh:PropertyGroup;
        rdfs:label  "Cardinality";
        sh:order    0 .
