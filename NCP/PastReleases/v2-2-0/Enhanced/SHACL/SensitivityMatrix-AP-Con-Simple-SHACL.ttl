sm:Ontology  rdf:type     owl:Ontology;
        dcterms:conformsTo    "file://CGMES-30v25_501-20v01.eap" , "urn:iso:std:iec:61970-401:draft:ed-1" , "file://iec61970cim17v40_iec61968cim13v13a_iec62325cim03v17a.eap" , "urn:iso:std:iec:61970-600-2:ed-1" , "urn:iso:std:iec:61970-501:draft:ed-2" , "urn:iso:std:iec:61970-301:ed-7:amd1";
        dcterms:description   "Describing constraints extracted from RDFS.";
        dcterms:identifier    "urn:uuid3cca0822-7a7d-436d-b9b4-9ec843c0c6ce";
        dcterms:issued        "2025-10-04T07:02:11.865850700"^^xsd:dateTime;
        dcterms:language      "en-GB";
