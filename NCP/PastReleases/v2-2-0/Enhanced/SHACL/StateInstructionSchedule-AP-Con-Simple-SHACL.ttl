        sh:property           [ sh:path  nc:GLSKBidActionDistribution.GLSKSchedule ];
        sh:property           [ sh:path  nc:GLSKBidActionDistribution.PowerBidSchedule ];
        sh:severity           sh:Info;
        sh:targetClass        nc:GLSKBidActionDistribution .

sis:GLSKBidActionDistribution
        rdf:type        sh:NodeShape;
        sh:property     ido:IdentifiedObject.name-datatype , ido:IdentifiedObject.name-cardinality , ido:IdentifiedObject.description-datatype , ido:IdentifiedObject.description-cardinality , ido:IdentifiedObject.mRID-datatype , ido:IdentifiedObject.mRID-cardinality , sis:GLSKBidActionDistribution.GLSKSchedule-valueType , sis:GLSKBidActionDistribution.GLSKSchedule-cardinality , sis:GLSKBidActionDistribution.PowerBidSchedule-valueType , sis:GLSKBidActionDistribution.PowerBidSchedule-cardinality;
        sh:targetClass  nc:GLSKBidActionDistribution .

cc:     rdf:type     owl:Ontology;
        owl:imports  sh:;
        sh:declare   [ rdf:type      sh:PrefixDeclaration;
                       sh:namespace  "http://www.w3.org/1999/02/22-rdf-syntax-ns#";
                       sh:prefix     "rdf"
                     ] .

cc:ClassCount-propertySparql
        rdf:type     sh:SPARQLConstraint;
        sh:message   "The class {?class} appears {?value} times in the data graph.";
        sh:prefixes  cc:;
        sh:select    """ 
            SELECT $this ?class (COUNT(?instance) AS ?value)
            WHERE {
                    ?instance rdf:type ?class .
                   }
            GROUP BY $this ?class
             """ .

cc:ClassCount-property
        rdf:type        sh:PropertyShape;
        sh:description  "Counts instance of classes present in the data graph.";
        sh:group        cc:ClassesCountGroup;
        sh:name         "ClassCount";
        sh:order        1;
        sh:path         rdf:type;
        sh:severity     sh:Info;
        sh:sparql       cc:ClassCount-propertySparql .

cc:ClassCount-node  rdf:type  sh:NodeShape;
        sh:property    cc:ClassCount-property;
        sh:targetClass  dcat:Dataset, md:FullModel .

cc:ClassesCountGroup  rdf:type  sh:PropertyGroup;
        rdfs:label  "ClassesCount";
        sh:order    1 .

sis:AllowedClasses-property
        rdf:type        sh:PropertyShape;
        sh:description  "Checks if the dataset contains classes which are not defined in the profile to which this dataset conforms to.";
        sh:group        sis:ProfileClassesGroup;
        sh:in           ( nc:GLSKBidActionDistribution nc:ParticipationFactorTimePoint nc:PowerBidScheduleTimePoint nc:AvailabilityTimePoint nc:PowerBidDependency nc:PowerBidSchedule nc:ContingencySchedule nc:AssessedElementTimePoint nc:ContingencyTimePoint nc:GridStateIntensitySchedule nc:GenericValueSchedule nc:AssessedElementSchedule nc:GenericEnablingSchedule nc:GenericAvailableSchedule nc:EnablingTimePoint nc:GLSKSchedule nc:GenericValueTimePoint md:FullModel dm:DifferenceModel dcat:Dataset );
        sh:message      "This class is not part of the profile to which this dataset conforms to.";
        sh:name         "ClassNotInProfile";
        sh:order        1;
        sh:path         rdf:type;
        sh:severity     sh:Info .

sis:AllowedClasses-node
        rdf:type             sh:NodeShape;
        sh:property          sis:AllowedClasses-property;
        sh:targetSubjectsOf  rdf:type .

sis:ProfilePropertiesGroup
        rdf:type    sh:PropertyGroup;
        rdfs:label  "ProfileProperties";
        sh:order    1 .

sis:AssociationsGroup
        rdf:type    sh:PropertyGroup;
        rdfs:label  "Associations";
        sh:order    2 .

ido:DatatypesGroupIO  rdf:type  sh:PropertyGroup;
        rdfs:label  "DatatypesIO";
        sh:order    1 .

sis:ProfileClassesGroup
        rdf:type    sh:PropertyGroup;
        rdfs:label  "ProfileClasses";
        sh:order    1 .

sis:InverseAssociationsGroup
        rdf:type    sh:PropertyGroup;
        rdfs:label  "InverseAssociations";
        sh:order    1 .

sis:DatatypesGroup  rdf:type  sh:PropertyGroup;
        rdfs:label  "Datatypes";
        sh:order    1 .

ido:CardinalityGroup  rdf:type  sh:PropertyGroup;
        rdfs:label  "CardinalityIO";
        sh:order    0 .

sis:CardinalityGroup  rdf:type  sh:PropertyGroup;
        rdfs:label  "Cardinality";
        sh:order    0 .
