sis:GenericValueTimePoint.GenericValueSchedule-valueType
        rdf:type        sh:PropertyShape;
        sh:description  "This constraint validates the value of the association at the used direction.";
        sh:group        sis:AssociationsGroup;
        sh:in           ( nc:GenericValueSchedule nc:GridStateIntensitySchedule );
        sh:message      "One of the following occurs: 1) The value is not IRI; 2) The value is not the right class.";
        sh:name         "GenericValueTimePoint.GenericValueSchedule-valueType";
        sh:nodeKind     sh:IRI;
        sh:order        28;
        sh:path         ( nc:GenericValueTimePoint.GenericValueSchedule rdf:type );
        sh:severity     sh:Violation .

sis:GenericValueTimePoint.GenericValueSchedule-valueTypeNodeShape
        rdf:type        sh:NodeShape;
        sh:property     sis:GenericValueTimePoint.GenericValueSchedule-valueType;
        sh:targetClass  nc:GenericValueTimePoint .

sis:GenericValueTimePoint.GenericValueSchedule-cardinality
        rdf:type        sh:PropertyShape;
        sh:description  "This constraint validates the cardinality of the association at the used direction.";
        sh:group        sis:CardinalityGroup;
        sh:maxCount     1;
        sh:message      "Association with cardinality violation at the used direction.";
        sh:minCount     1;
        sh:name         "GenericValueTimePoint.GenericValueSchedule-cardinality";
        sh:order        95;
        sh:path         nc:GenericValueTimePoint.GenericValueSchedule;
        sh:severity     sh:Violation .

